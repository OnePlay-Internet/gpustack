# Copy to .env and edit. Used by docker-compose.shared-infra.yaml.

# ---- Image ----
IMAGE_REGISTRY=docker.io
IMAGE_NAMESPACE=gpustack
GPUSTACK_TAG=latest

# ---- Shared database (remote host) ----
# Scheme: mysql | postgresql
DB_SCHEME=mysql
DB_HOST=172.28.77.202
DB_PORT=3306
DB_NAME=gpustack
DB_USER=gpustack
DB_PASSWORD=gpustack_pass

# ---- Shared Grafana (must be browser-reachable) ----
GRAFANA_URL=http://172.28.77.202:3000
GRAFANA_WORKER_DASHBOARD_UID=gpustack-worker
GRAFANA_MODEL_DASHBOARD_UID=gpustack-model

# ---- Admin bootstrap (first init only) ----
BOOTSTRAP_PASSWORD=admin
